###############################################
# Configuration IA - Exemple de fichier .env  #
###############################################
#
# IMPORTANT : copiez ce fichier vers ".env" puis renseignez vos clés.
#   cp env.example .env
# Le code ne lit QUE le fichier .env (jamais env.example).
# Ne committez JAMAIS votre fichier .env (il est ignoré par .gitignore).
#
# Deux modèles par fournisseur :
#   *_MODEL_PREPROCESS  -> prétraitement (mise en forme HTML des appréciations)
#   *_MODEL_GENERATION  -> rédaction de l'appréciation générale

# Fournisseur IA actif : openai | anthropic | gemini
AI_ENABLED_PROVIDER=openai

# --- OpenAI ---------------------------------------------------------
# Clé : https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL_PREPROCESS=gpt-5-mini
OPENAI_MODEL_GENERATION=gpt-5-mini

# --- Anthropic (Claude) ---------------------------------------------
# Clé : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_PREPROCESS=claude-sonnet-4-6
ANTHROPIC_MODEL_GENERATION=claude-sonnet-4-6

# --- Google (Gemini) ------------------------------------------------
# Clé : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL_PREPROCESS=gemini-2.5-flash
GEMINI_MODEL_GENERATION=gemini-2.5-flash
